{
  "name": "@ctrlr/core",
  "version": "0.1.0",
  "description": "Ctrlr engine: wires controller input → bindings → actions → pane host.",
  "license": "MIT",
  "author": "mpge",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpge/ctrlr.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ctrlr/bindings": "workspace:*",
    "@ctrlr/controller-input": "workspace:*",
    "@ctrlr/pane-host": "workspace:*",
    "@ctrlr/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
