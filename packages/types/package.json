{
  "name": "@ctrlr/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for the Ctrlr platform.",
  "license": "MIT",
  "author": "mpge",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpge/ctrlr.git",
    "directory": "packages/types"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
