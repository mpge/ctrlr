{
  "name": "@ctrlr/cli",
  "version": "0.1.0",
  "description": "Ctrlr command-line: control your AI agents like a game controller.",
  "license": "MIT",
  "author": "mpge",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpge/ctrlr.git",
    "directory": "apps/cli"
  },
